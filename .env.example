# TrinityHouse uses the same Azure PostgreSQL server as Viggil.
# Server: viggil-db.postgres.database.azure.com
# Get the connection string from Credentials_And_Keys.md or miscinfo.txt (Viggil DATABASE_URL).
# Do not commit .env or put real passwords in the repo.

DATABASE_URL=postgresql://USER:PASSWORD@viggil-db.postgres.database.azure.com:5432/postgres?sslmode=require

# Auth: set a strong secret in production. Used for signing session cookies.
JWT_SECRET=your-random-secret-at-least-32-chars

# Superuser (for npm run db:seed-auth only). Do not commit real values.
# SUPERUSER_EMAIL=chuksa@gmail.com
# SUPERUSER_PASSWORD=your-password

# Paystack (primary Nigerian payments). Get keys from https://dashboard.paystack.com/#/settings/developers
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
# PAYSTACK_SECRET_KEY=sk_live_...

# Stripe (secondary, international cards). Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Optional: for recording donations via webhook. In Stripe Dashboard add events: checkout.session.completed, payment_intent.succeeded
# STRIPE_GIVING_WEBHOOK_SECRET=whsec_...
