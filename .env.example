# TrinityHouse uses the same Azure PostgreSQL server as Viggil.
# Server: viggil-db.postgres.database.azure.com
# Get the connection string from Credentials_And_Keys.md or miscinfo.txt (Viggil DATABASE_URL).
# Do not commit .env or put real passwords in the repo.

DATABASE_URL=postgresql://USER:PASSWORD@viggil-db.postgres.database.azure.com:5432/postgres?sslmode=require
